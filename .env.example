# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for UtilityHub (Next.js frontend)
#
# LOCAL DEV:
#   Copy this file to .env.local and fill in the values below.
#   .env.local is git-ignored — never commit it.
#
# AZURE STATIC WEB APPS:
#   Set these in Azure Portal → Static Web App → Configuration → Application Settings.
#   NEXT_PUBLIC_* variables are embedded at build time; they are NOT secret.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Spring Cloud Gateway (upstream for all API calls)
# Local dev  → http://localhost:8080/v1
# Azure      → https://<your-gateway-name>.<region>.azurecontainerapps.io/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1
